{
  "name": "price-tracker-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node apps/server/src/index.js",
    "start": "node apps/server/src/index.js",
    "worker": "node apps/server/src/workers/price-drop-worker.js",
    "scrape:product": "node apps/server/src/scripts/scrape-product.js",
    "db:schema": "node -e \"console.log('Apply infra/postgres/schema.sql with psql or your migration tool.')\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  }
}
