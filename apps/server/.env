# Server kis port par chalega (default 4000)
PORT=4000

# Aapke PostgreSQL database ka rasta (Sabse jaruri)
# Format: postgres://USERNAME:PASSWORD@localhost:5432/DATABASE_NAME
DATABASE_URL=postgres://postgres:admin123@localhost:5432/price_tracker

# Scraping ke liye samay (milliseconds mein)
SCRAPE_TIMEOUT_MS=45000

# Price check karne ka schedule (Har ghante ke liye niche wala rehne dein)
PRICE_CHECK_CRON=0 * * * *

# Scraper ko piche chalane ke liye 'true' rakhein
PLAYWRIGHT_HEADLESS=true

# Agar aapke paas notification bhejne ke liye webhook hai toh yahan likhein
PRICE_ALERT_WEBHOOK_URL=
